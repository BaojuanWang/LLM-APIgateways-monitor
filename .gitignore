__pycache__/
*.pyc

# Per-run master snapshots regenerate from sources; keep them out of git.
results/master/snapshots/

# ---------------------------------------------------------------------------
# Local WACZ archive subsystem (see docs/LOCAL_WACZ_ARCHIVE.md)
#
# The canonical raw corpus lives ONLY under $ARCHIVE_ROOT on an external volume
# and is never expected inside this working tree. These rules are a backstop for
# the case where something is written here by mistake — they are narrow on
# purpose. Verified against `git ls-files`: none of them match a tracked file.
# ---------------------------------------------------------------------------
.archive-local/
archive/runtime/
*.wacz
*.warc
*.warc.gz
*.cdxj
*.singlefile.html

# Any corpus accidentally rooted inside the repository.
corpus/
**/corpus/*/captures/
archive/tests/.tmp/
