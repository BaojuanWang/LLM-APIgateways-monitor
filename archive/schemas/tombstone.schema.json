{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BaojuanWang/LLM-APIgateways-monitor/archive/schemas/tombstone.schema.json",
  "title": "Service tombstone",
  "description": "Immutable record that a service appears to have ended. This is EVIDENCE WITH A CONFIDENCE LEVEL, not a death certificate: the monitor observes from one vantage point on a six-hour cadence, so a single failure never produces a tombstone and a reappearance produces a new record rather than deleting this one.",
  "type": "object",
  "required": [
    "service_id",
    "recorded_at_utc",
    "prior_state",
    "new_state",
    "confidence",
    "evidence",
    "final_capture_attempted",
    "uncertainty"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": { "type": "string" },
    "service_id": { "type": "string" },
    "host": { "type": "string" },
    "recorded_at_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "prior_state": {
      "type": "string",
      "description": "Monitor online_status at the last live observation."
    },
    "new_state": {
      "type": "string",
      "enum": [
        "dns_failure_persistent",
        "http_failure_persistent",
        "unreachable_persistent",
        "service_stopped",
        "parked_or_for_sale",
        "redirects_offsite",
        "unavailable_persistent",
        "unknown_not_live",
        "live"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": ["insufficient", "provisional", "probable", "high"],
      "description": "insufficient = do not cite as termination. Blocked/challenge responses can never exceed 'insufficient' because they prove the origin is answering."
    },
    "is_provisional": { "type": "boolean" },
    "evidence": {
      "type": "object",
      "required": ["consecutive_observations", "span_hours"],
      "properties": {
        "source": {
          "type": "object",
          "description": "Which monitor file, and its SHA256, supported this conclusion."
        },
        "consecutive_observations": { "type": "integer", "minimum": 0 },
        "span_hours": { "type": "number", "minimum": 0 },
        "first_terminal_observation_utc": { "type": "string" },
        "last_terminal_observation_utc": { "type": "string" },
        "last_live_observation_utc": { "type": "string" },
        "inconclusive_observation_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Blocked/challenge observations inside the trailing run. Higher values weaken the conclusion."
        },
        "redirect_target_host": { "type": "string" },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string" },
              "online_status": { "type": "string" },
              "http_status": { "type": ["string", "integer", "null"] },
              "final_url": { "type": "string" },
              "error": { "type": "string" }
            }
          }
        }
      }
    },
    "last_successful_capture_id": { "type": ["string", "null"] },
    "last_successful_wacz_sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
    "final_capture_attempted": { "type": "boolean" },
    "final_capture_result": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "uncertainty": {
      "type": "string",
      "description": "Mandatory prose statement of the limits of this record."
    }
  }
}
