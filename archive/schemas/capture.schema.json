{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BaojuanWang/LLM-APIgateways-monitor/archive/schemas/capture.schema.json",
  "title": "Capture metadata",
  "description": "Written once per capture as capture.json. Immutable: a retry produces a new capture_id rather than editing this file. A failed capture is still a valid document — 'we tried and this is what we saw' is the evidence.",
  "type": "object",
  "required": [
    "capture_id",
    "service_id",
    "host",
    "started_utc",
    "capture_reason",
    "status",
    "effective_config_hash",
    "seed_count",
    "wacz"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": { "type": "string" },
    "capture_id": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z_[a-z0-9][a-z0-9-]*_[0-9a-f]{8}_[0-9a-f]{12}$",
      "description": "<UTC compact>_<service_id>_<12 hex of a hash over service, seeds, config, timestamp>."
    },
    "service_id": { "type": "string" },
    "host": { "type": "string" },
    "canonical_url": { "type": "string" },
    "platform_name": { "type": "string" },
    "source": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "started_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "ended_utc": { "type": ["string", "null"] },
    "capture_reason": {
      "type": "string",
      "enum": [
        "first_capture",
        "status_transition",
        "reappearance",
        "homepage_hash_change",
        "final_url_change",
        "title_change",
        "tombstone_evidence",
        "monthly_interval",
        "retry_failure",
        "manual",
        "smoke_test"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed_no_wacz", "aborted", "dry_run"],
      "description": "Whether the capture produced a WACZ. Independent of whether the SITE was healthy."
    },
    "site_condition": {
      "type": "string",
      "enum": [
        "ok",
        "redirected_offsite",
        "blocked_or_challenge",
        "parked_or_for_sale",
        "service_stopped",
        "unavailable",
        "unknown"
      ],
      "description": "What the site looked like, as distinct from whether the capture succeeded."
    },
    "effective_config_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "code_commit_sha": { "type": ["string", "null"] },
    "seed_count": { "type": "integer", "minimum": 1, "maximum": 25 },
    "seeds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "page_type", "origin"],
        "properties": {
          "url": { "type": "string" },
          "page_type": {
            "type": "string",
            "enum": [
              "homepage",
              "login",
              "registration",
              "pricing",
              "documentation",
              "model_list",
              "public_status",
              "privacy_policy",
              "terms",
              "announcements",
              "public_api"
            ]
          },
          "origin": { "type": "string", "enum": ["canonical", "homepage", "known_path", "api_path"] },
          "evidence": { "type": "string" },
          "http_status": { "type": ["integer", "null"] },
          "present": { "type": "boolean" }
        }
      }
    },
    "missing_page_types": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Page types not found. Recorded as missing rather than fabricated."
    },
    "page_count": { "type": "integer", "minimum": 0 },
    "collection": { "type": "string" },
    "wacz": {
      "type": "object",
      "description": "The canonical archival artifact. Null fields mean no WACZ was produced; SingleFile and screenshots never substitute for it.",
      "properties": {
        "relative_path": { "type": ["string", "null"] },
        "size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "browsertrix_exit_code": { "type": ["integer", "null"] },
    "browsertrix_timed_out": { "type": "boolean" },
    "rendered": { "type": "object" },
    "singlefile": { "type": "array" },
    "tools": {
      "type": "object",
      "properties": {
        "browsertrix": {
          "type": "object",
          "properties": {
            "image": { "type": "string" },
            "tag": { "type": "string" },
            "digest": { "type": ["string", "null"] },
            "reference": { "type": "string" }
          }
        },
        "singlefile": { "type": "object" }
      }
    },
    "prior_monitor_state": { "type": "object" },
    "monitor_source": { "type": "object" },
    "corpus_relpath": {
      "type": "string",
      "description": "Path relative to $ARCHIVE_ROOT. Never absolute — absolute paths would leak the operator's filesystem layout."
    },
    "errors": { "type": "array", "items": { "type": "string" } },
    "immutability": { "type": "string" }
  }
}
